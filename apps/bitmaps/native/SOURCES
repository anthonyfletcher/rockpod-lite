/* Bitmaps compiled into the core build for the native (colour) LCD.
 *
 * This fork targets the iPod Video 5G/5.5G and iPod Classic 6G/7G only, both
 * 320x240 16-bit. The upstream variants for every other screen size, and the
 * bootloader menu icons for the Sony/AGPTek/xDuoo/FiiO players, have been
 * deleted -- they were never selected here. The size conditionals below are
 * kept only where a real choice remains. */

#ifndef BOOTLOADER  /* We don't need these for the bootloader */

/* Boot logo, shown centered by show_logo_boot() in apps/main.c */
rockpodlogo.bmp

/* Album covers' "no artwork found" placeholder slide -- see
 * create_empty_slide() in apps/screens/covers/album_covers.c */
#ifdef HAVE_TAGCACHE
no_album_cover.bmp
/* "No artist photo" placeholder for database artist rows -- see
 * aa_ensure_fallback() in apps/metadata/art_cache.c */
rockpodnoartistcover.bmp
#endif

/* Full-screen custom USB (eject) screen for the 320x240 iPods */
#if defined(HAVE_LCD_COLOR) && (LCD_WIDTH == 320) && (LCD_HEIGHT == 240)
rockpodusb.bmp
#endif

/* Full-screen loading splash for the core text viewer (320x240 iPods) */
#if defined(HAVE_LCD_COLOR) && (LCD_WIDTH == 320) && (LCD_HEIGHT == 240)
rockpodtext.bmp
#endif

/* Full-screen loading splash for the core image viewer (320x240 iPods) */
#if defined(HAVE_LCD_COLOR) && (LCD_WIDTH == 320) && (LCD_HEIGHT == 240)
rockpodpicture.bmp
#endif

/* Left-hand artwork panel for the core credits screen (320x240 iPods) */
#if defined(HAVE_LCD_COLOR) && (LCD_WIDTH == 320) && (LCD_HEIGHT == 240)
rockpodcredits.bmp
#endif

#endif /* BOOTLOADER */
