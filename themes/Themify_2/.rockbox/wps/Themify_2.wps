%V(196,154,124,29,6)%VB
%aR%?if(%mp,<=,3)<%?mv(1)<ÍÎ|%?mp<ÃÄ|ÉÊ|ÃÄ>>|ÃÄ>%?if(%ft(themes/Themify_2.preferences,minimal player mode:),=,on)<|%?if(%pe,!=,1)<ÇÇ>>È
#
