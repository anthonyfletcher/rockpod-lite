#--- Album Art ---# $AA
#
# in this instance the character u is a 14% opacity block used to shade the background.
%Vd(Album_Widget)%?C<%Vd(Album_Art)|%Vd(Album_Fallback_Art)>
%Vl(Album_Art,0,22,160,160,9)%VB%Cl(0,0,160,160)%Cdvvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
%Vl(Album_Fallback_Art,0,22,160,42,9)%VB
uuuuuuu
uuuuuuu
%Vl(Album_Fallback_Art,0,64,160,100,9)%VB
abcdeuw
fghijuw
klmnopw
uuqrstw
%Vl(Album_Fallback_Art,0,164,160,18,9)%VB
uuuuuuu
#
%Vl(Album_Fallback_Art,0,22,160,160,-)
%V(159,22,1,1,-)%VB
%Vl(Album_Widget,0,16,145,6,-)%VB%dr(0,0,-,-)
%Vl(Album_Widget,160,38,6,128,-)%VB%dr(0,0,-,-)
%Vl(Album_Widget,160,38,6,128,-)%dr(0,0,-,-)
%Vl(Album_Widget,0,182,166,6,-)%VB%dr(0,0,-,-)
%Vl(Album_Widget,0,188,166,33,-)%dr(0,0,-,-)
# Redraw the album/fallback art on the foreground layer too, identical to
# the background layer's copy above -- previously this was just a bare
# viewport declaration with nothing drawn, so on a track/screen change the
# background layer's art appeared instantly while the foreground layer
# caught up a frame later with nothing there yet, then repainted over it --
# a brief but visible flash. Matches the same draw-on-both-layers pattern
# already used for the corner/shadow rects above.
%Vl(Album_Art,0,22,160,160,9)%Cl(0,0,160,160)%Cdvvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
%Vl(Album_Fallback_Art,0,22,160,42,9)
uuuuuuu
uuuuuuu
%Vl(Album_Fallback_Art,0,64,160,100,9)
abcdeuw
fghijuw
klmnopw
uuqrstw
%Vl(Album_Fallback_Art,0,164,160,18,9)
uuuuuuu
# draw the rounded edges
# Background-layer copies added below: these had no %VB counterpart at
# all, unlike the art itself and the shadow rects above -- so on a track
# change the background layer's fresh art appeared instantly with no
# corner glyphs yet, and the foreground layer then popped them in a frame
# later, reading as a piece getting drawn over the top-right of the art.
%Vl(Album_Widget,0,16,166,22,6)%VB%aRb
%Vl(Album_Widget,0,166,166,22,6)%VB%aRc
%Vl(Album_Widget,144,199,22,22,6)%VBd
%Vl(Album_Widget,0,16,166,22,6)%aRb
%Vl(Album_Widget,0,166,166,22,6)%aRc
%Vl(Album_Widget,144,199,22,22,6)d
