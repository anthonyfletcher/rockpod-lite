# ===== =    = ===== ==   == ===== ===== =   =
#   =   ====== ===   = === =   =   ===   =====
#   =   =    = ===== =  =  = ===== =       =
# 
#	     Themify 2 - aquamarine
#		   Dook  2025
#
#-----------------------------------------------#
#	Search Index
#	----------------------
#	$VD - Viewport Declarations
#	$GR - Graphics Reset
#	$FL - Font-loading
#	$AA - Album Art
#	$SB - Status Bar
#	$PS - Player & Playlist Status
#	$SI - Song Info
#	----------------------
#
#--- Viewport Declarations ---# $VD
# these need to be here to prevent rendering issues.
#
# CC: $VD picks which title viewport to show up front. It measures the
# CC: track title length (%ss slices of %it) and, if it fits on one line,
# CC: uses a single-line title; otherwise it splits into a dual-line title
# CC: at the right space. 'High_' variants are used when two sublines show.
%?or(%if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,off),%if(%ft(themes/Themify_2.preferences,sub-line mode:),=,off))<%?and(%if(%tw(%it,2), <=, 264),%if(%tw(%it,2), >, 132))<%Vd(Dual_Line_Song_Title)|%Vd(Single_Line_Song_Title)>|%?and(%if(%tw(%it,2), <=, 264),%if(%tw(%it,2), >, 132))<%Vd(High_Dual_Line_Song_Title)|%Vd(High_Single_Line_Song_Title)>>
#
# CC: Then pick the subline viewport(s) from the theme prefs (sub-line mode
# CC: / extra sub-line mode: artist, album, rating, file_format, year,
# CC: volume_meter, off...).
%?and(%if(%tw(%it,2), <=, 264),%if(%tw(%it,2), >, 132))<%?if(%ft(themes/Themify_2.preferences,sub-line mode:),=,volume_meter)<%Vd(Dual_Line_Subline_Volume_Meter)|%?if(%ft(themes/Themify_2.preferences,sub-line mode:),=,off)<%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,rating)<%Vd(Dual_Line_Subline_Rating)|%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,file_format)<%Vd(Dual_Line_File_Format)|%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,year)<%Vd(Dual_Line_Song_Year)|%Vd(Dual_Line_Subline_Text)>>>|%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,off)<%Vd(Dual_Line_Subline_Text)|%Vd(High_Dual_Line_Subline_Text)%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,rating)<%Vd(High_Dual_Line_Subline_Rating)|%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,file_format)<%Vd(High_Dual_Line_File_Format)|%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,year)<%Vd(High_Dual_Line_Song_Year)|%Vd(High_Dual_Line_Extra_Subline_Text)>>>>>>|%?if(%ft(themes/Themify_2.preferences,sub-line mode:),=,volume_meter)<%Vd(Single_Line_Subline_Volume_Meter)|%?if(%ft(themes/Themify_2.preferences,sub-line mode:),=,off)<%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,rating)<%Vd(Single_Line_Subline_Rating)|%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,file_format)<%Vd(Single_Line_File_Format)|%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,year)<%Vd(Single_Line_Song_Year)|%Vd(Single_Line_Subline_Text)>>>|%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,off)<%Vd(Single_Line_Subline_Text)|%Vd(High_Single_Line_Subline_Text)%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,rating)<%Vd(High_Single_Line_Subline_Rating)|%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,file_format)<%Vd(High_Single_Line_File_Format)|%?if(%ft(themes/Themify_2.preferences,extra sub-line mode:),=,year)<%Vd(High_Single_Line_Song_Year)|%Vd(High_Single_Line_Extra_Subline_Text)>>>>>>>
#
#- Battery -#
# CC: Enable numeric or graphical battery per the theme setting.
%?St(battery display)<%Vd(Battery_Graphical)|%Vd(Battery_Numeric)>
#
#- Status Bar -#
# CC: Enable the status bar; the 'Long' variant when a sleep timer (%bs) or
# CC: hold (%mh) icon is present, plus the sub-status icons unless minimal mode.
%?bs<%Vd(Status_Bar_Long)|%?mh<%Vd(Status_Bar_Long)|%Vd(Status_Bar_Short)>>%Vd(Status_Bar)%?if(%ft(themes/Themify_2.preferences,minimal player mode:),=,on)<|%?bs<%Vd(Sub_Status_Bar_Long)|%?mh<%Vd(Sub_Status_Bar_Long)|%Vd(Sub_Status_Bar_Short)>>>
#
#- Playlist Position -#
%?if(%ft(themes/Themify_2.preferences,minimal player mode:),=,on)<|%?if(%pe,!=,1)<%?if(%pe, >=, 100)<%Vd(Playlist_Position_Three_Lines)|%Vd(Playlist_Position_Single_Line)>>>
#
%?if(%ft(themes/Themify_2.preferences,minimal player mode:),=,on)<|%?or(%if(%bs,=,%bs),%if(%mh,=,h))<|%Vd(Sub_Status_Backdrop_Long)%Vd(Sub_Status_Backdrop_Long_Flush)|%Vd(Sub_Status_Backdrop_Short)%Vd(Sub_Status_Backdrop_Short_Flush)>>
#
#--- END ---#
#
#
#--- Graphics Reset ---# $GR
# need to flush the background and foreground, or the previous screen's background remains.
# CC: $GR: flush both layers so the previous screen's background doesn't
# CC: bleed through; %wd disables the default statusbar.
%V(0,0,-,-,-)%VB
%V(0,0,-,-,-)
%wd
#
#--- END ---#
#
#
#--- Font-loading ---# $FL
# CC: $FL: preload the fonts used below (title, artist/album, and the icon
# CC: fonts). The number is the font id referenced as the last %V/%Vl arg.
%Fl(2,22-LeagueSpartan-Bold.fnt) # song titles font
%Fl(3,18-LeagueSpartan-Medium.fnt) # artist/album and playlist position font
%Fl(4,../wps/Themify_2/Player_Icons.fnt) # vector icons for the song playback status
%Fl(5,../wps/Themify_2/16-LeagueSpartan-SemiBold.fnt) # numeric battery Font
%Fl(6,../wps/Themify_2/UI_Vectors.fnt) # ui drawing vectors
%Fl(7,../wps/Themify_2/Blank_Font.fnt,5) # blank font
%Fl(8,../wps/Themify_2/14x13_Compacticons.fnt,120) # vector icons for the status bar
%Fl(9,../wps/Themify_2/Graphics_Font.fnt) # vector icons 
#
#--- END ---#
#
#
#--- Album Art ---# $AA
#
# in this instance the character u is a 14% opacity block used to shade the background.
# CC: $AA: draw the album-art frame, then the real art (%C = art available)
# CC: or the fallback placeholder.
%Vd(Album_Widget)%?C<%Vd(Album_Art)|%Vd(Album_Fallback_Art)>
# CC: Load the album art into a 160x160 area (%Cl position, %Cd draw); the
# CC: 'v' rows shade the backdrop behind it.
%Vl(Album_Art,0,22,160,160,9)%VB%Cl(0,0,160,160)%Cdvvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
vvvvvvv
%Vl(Album_Fallback_Art,0,22,160,42,9)%VB
uuuuuuu
uuuuuuu
%Vl(Album_Fallback_Art,0,64,160,100,9)%VB
abcdeuw
fghijuw
klmnopw
uuqrstw
%Vl(Album_Fallback_Art,0,164,160,18,9)%VB
uuuuuuu
#
%Vl(Album_Fallback_Art,0,22,160,160,-)
%V(159,22,1,1,-)%VB
# CC: The rounded frame/mask drawn around the album art.
%Vl(Album_Widget,0,16,145,6,-)%VB%dr(0,0,-,-)
%Vl(Album_Widget,160,38,6,128,-)%VB%dr(0,0,-,-)
%Vl(Album_Widget,160,38,6,128,-)%dr(0,0,-,-)
%Vl(Album_Widget,0,182,166,6,-)%VB%dr(0,0,-,-)
%Vl(Album_Widget,0,188,166,33,-)%dr(0,0,-,-)
# cutout the visible album art in the foreground layer
%Vl(Album_Art,0,38,160,128,-)
# draw the rounded edges
%Vl(Album_Widget,0,16,166,22,6)%aRb
%Vl(Album_Widget,0,166,166,22,6)%aRc
%Vl(Album_Widget,144,199,22,22,6)d
#
#-- Song Position --#
#
# for cuesheet bookmarks
%V(18,191,126,5,-)%VB%dr(0,0,-,-)
%V(18,191,126,5,-)%pb(0,0,-,-,noborder)
#
#
%V(17,196,127,5,7)%VB
#
#- Custom Player Slider Legend -#
# Ø = Slider Rounded Start
# Ò = Slider Rounded End
# Ñ = 1px
# Ô = 5px
# Õ = 10px
# Ö = 20px
# × = 25px
# Ó = Slider BG Rounded End
#
# CC: Custom progress slider. %px = playback position (0-100); the glyph
# CC: string builds a rounded bar of the right length (see legend above).
%V(17,196,127,5,6)%aLØ%aR%?px<ÒÖ××××Ó|ÒÖ××××Ó|ÒÑÑÑÑÔÕ××××Ó|ÒÑÑÑÔÕ××××Ó|ÒÑÑÔÕ××××Ó|ÒÑÔÕ××××Ó|ÒÔÕ××××Ó|ÒÑÑÑÑÕ××××Ó|ÒÑÑÑÕ××××Ó|ÒÑÑÕ××××Ó|ÒÑÕ××××Ó|ÒÕ××××Ó|ÒÑÑÑÑÔ××××Ó|ÒÑÑÑÔ××××Ó|ÒÑÑÔ××××Ó|ÒÑÔ××××Ó|ÒÔ××××Ó|ÒÑÑÑÑ××××Ó|ÒÑÑÑ××××Ó|ÒÑÑ××××Ó|ÒÑ××××Ó|Ò××××Ó|ÒÑÑÑÑÖ×××Ó|ÒÑÑÑÖ×××Ó|ÒÑÑÖ×××Ó|ÒÑÑÖ×××Ó|ÒÑÖ×××Ó|ÒÖ×××Ó|ÒÑÑÑÑÔÕ×××Ó|ÒÑÑÑÔÕ×××Ó|ÒÑÑÔÕ×××Ó|ÒÑÔÕ×××Ó|ÒÔÕ×××Ó|ÒÑÑÑÑÕ×××Ó|ÒÑÑÑÕ×××Ó|ÒÑÑÕ×××Ó|ÒÑÕ×××Ó|ÒÕ×××Ó|ÒÑÑÑÑÔ×××Ó|ÒÑÑÑÔ×××Ó|ÒÑÑÔ×××Ó|ÒÑÔ×××Ó|ÒÔ×××Ó|ÒÑÑÑÑ×××Ó|ÒÑÑÑ×××Ó|ÒÑÑ×××Ó|ÒÑ×××Ó|Ò×××Ó|ÒÑÑÑÑÖ××Ó|ÒÑÑÑÖ××Ó|ÒÑÑÖ××Ó|ÒÑÖ××Ó|ÒÖ××Ó|ÒÑÑÑÑÔÕ××Ó|ÒÑÑÑÔÕ××Ó|ÒÑÑÔÕ××Ó|ÒÑÔÕ××Ó|ÒÔÕ××Ó|ÒÑÑÑÑÕ××Ó|ÒÑÑÑÕ××Ó|ÒÑÑÕ××Ó|ÒÑÕ××Ó|ÒÕ××Ó|ÒÑÑÑÑÔ××Ó|ÒÑÑÑÔ××Ó|ÒÑÑÔ××Ó|ÒÑÔ××Ó|ÒÔ××Ó|ÒÑÑÑÑ××Ó|ÒÑÑÑ××Ó|ÒÑÑ××Ó|ÒÑ××Ó|Ò××Ó|ÒÑÑÑÑÖ×Ó|ÒÑÑÑÖ×Ó|ÒÑÑÖ×Ó|ÒÑÖ×Ó|ÒÖ×Ó|ÒÑÑÑÑÔÕ×Ó|ÒÑÑÑÔÕ×Ó|ÒÑÑÔÕ×Ó|ÒÑÔÕ×Ó|ÒÔÕ×Ó|ÒÑÑÑÑÕ×Ó|ÒÑÑÑÕ×Ó|ÒÑÑÕ×Ó|ÒÑÕ×Ó|ÒÕ×Ó|ÒÑÑÑÑÔ×Ó|ÒÑÑÑÔ×Ó|ÒÑÑÔ×Ó|ÒÑÔ×Ó|ÒÔ×Ó|ÒÑÑÑÑ×Ó|ÒÑÑÑ×Ó|ÒÑÑ×Ó|ÒÑ×Ó|Ò×Ó|ÒÑÑÑÑÖÓ|ÒÑÑÑÖÓ|ÒÑÑÖÓ|ÒÑÖÓ|ÒÖÓ|ÒÑÑÑÑÔÕÓ|ÒÑÑÑÔÕÓ|ÒÑÑÔÕÓ|ÒÑÔÕÓ|ÒÔÕÓ|ÒÑÑÑÑÕÓ|ÒÑÑÑÕÓ|ÒÑÑÕÓ|ÒÑÕÓ|ÒÕÓ|ÒÑÑÑÑÔÓ|ÒÑÑÑÔÓ|ÒÑÑÔÓ|ÒÑÔÓ|ÒÔÓ|ÒÑÑÑÑÓ|ÒÑÑÑÓ|ÒÑÑÓ|ÒÑÓ|ÒÓ|ÒÑ|Ù>
