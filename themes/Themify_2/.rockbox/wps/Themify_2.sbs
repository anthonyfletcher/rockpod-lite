#
%Vl(Menu_No_Icons,9,4,283,22,-)%?La<|%?and(%if(%LT,!=,%Sx([All tracks])),%if(%LT,!=,%Sx([Random])),%if(%LT,!=,%Sx([Untagged])),%if(%LT,!=,%Sx([By album])))<%?Lc<%Vs(invert)>%?if(%St(scroll speed),=,1)<|%s>%LT>>
#
# CC: Album-list layout (%?La true only). The skin renderer recurses once per
# CC: nesting level (skin_render_line), so these stay shallow -- depth, not
# CC: viewport count, is what overflows the stack. The baseline viewports above
# CC: are left untouched so ordinary lists keep their exact (safe) depth.
# CC: Cover on the left; %La self-blanks to the placeholder until the cache fills.
%Vl(Menu_No_Icons,2,2,48,48,-)%?La<%?and(%if(%LT,!=,%Sx([All tracks])),%if(%LT,!=,%Sx([Random])),%if(%LT,!=,%Sx([Untagged])),%if(%LT,!=,%Sx([By album])))<%La>|>
