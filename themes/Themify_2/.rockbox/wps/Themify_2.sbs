%Vl(Miniplayer_Album_Fallback_Art,205,25,111,111,-)
%Vl(Miniplayer_Widget,205,25,111,10,6)W%aRX
%Vl(Miniplayer_Widget,205,126,111,10,6)Y%aRZ
#
# CC: Track name under the art, word-wrapped rather than scrolled.
# CC: The skin engine has no wrap tag, so this follows the WPS approach:
# CC: pick a viewport whose %ss slices break on a space. $VD chooses.
# CC: 9 chars is what fits on a 103px line at font 3
# CC: (22-LeagueSpartan-Bold, maxwidth 24) -- the average glyph runs about
# CC: 0.45 of maxwidth, which is what gave font 4 its working 12.
# CC: Change the font and this width together, they are one decision.
# CC: %Vf is the theme BACKGROUND colour: the panel fill is %dr, which
# CC: defaults to the theme FOREGROUND, so default-coloured text would be
# CC: invisible against it. Setting it as the viewport fg (not
# CC: %Vs(color,..)) keeps it going through dynamic_colors_resolve(), so
# CC: it follows the album-art palette instead of freezing as navy.
%Vl(Panel_Title_Single,209,148,103,20,3)%Vf(000c21)%aL%?it<%it|%fn>
#
# CC: Break on a space, then hard-split whatever is left over the
# CC: remaining lines. Slices past the end of the string come back empty,
# CC: so a short remainder simply leaves the last line blank.
%Vl(Panel_Title_Space_9,209,148,103,62,3)%Vf(000c21)
%ss(0,10,%it)
%ss(10,19,%it)
%ss(19,28,%it)
%Vl(Panel_Title_Space_8,209,148,103,62,3)%Vf(000c21)
%ss(0,9,%it)
%ss(9,18,%it)
%ss(18,27,%it)
%Vl(Panel_Title_Space_7,209,148,103,62,3)%Vf(000c21)
%ss(0,8,%it)
%ss(8,17,%it)
%ss(17,26,%it)
%Vl(Panel_Title_Space_6,209,148,103,62,3)%Vf(000c21)
%ss(0,7,%it)
%ss(7,16,%it)
%ss(16,25,%it)
%Vl(Panel_Title_Space_5,209,148,103,62,3)%Vf(000c21)
%ss(0,6,%it)
%ss(6,15,%it)
%ss(15,24,%it)
%Vl(Panel_Title_Space_4,209,148,103,62,3)%Vf(000c21)
%ss(0,5,%it)
%ss(5,14,%it)
%ss(14,23,%it)
%Vl(Panel_Title_Space_3,209,148,103,62,3)%Vf(000c21)
%ss(0,4,%it)
%ss(4,13,%it)
%ss(13,22,%it)
#
# CC: No space to break on, or too long to wrap: hard split, no scrolling.
%Vl(Panel_Title_Long,209,148,103,62,3)%Vf(000c21)
%ss(0,9,%it)
%ss(9,18,%it)
%ss(18,27,%it)
